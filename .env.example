# .env.example — Copy to .env for local development.
#
# NEVER commit .env to version control.
# Add .env to your .gitignore.
#
# For EAS builds, set these as EAS environment variables:
#   eas env:create --name EXPO_PUBLIC_API_URL --value https://api.example.com --environment production
#   eas env:create --name EXPO_PUBLIC_CDN_URL --value https://cdn.example.com --environment production
#
# ──────────────────────────────────────────────────────────────────────────────
# Public variables (embedded in the JS bundle at build time — NOT secret)
# Only use EXPO_PUBLIC_ prefix for non-sensitive config.
# ──────────────────────────────────────────────────────────────────────────────

# Your backend API base URL (Cloudflare Workers, Express, etc.)
# Example: https://music-api.my-worker.workers.dev
EXPO_PUBLIC_API_URL=http://localhost:8787

# CDN base URL for audio files (Cloudflare R2, S3, etc.)
# Example: https://r2.example.com/audio
EXPO_PUBLIC_CDN_URL=http://localhost:8787

# ──────────────────────────────────────────────────────────────────────────────
# Secret variables (set in EAS secrets dashboard only — NOT in .env)
# These are never embedded in the client bundle.
# ──────────────────────────────────────────────────────────────────────────────
# UPLOAD_SIGNING_SECRET=PLACEHOLDER_DO_NOT_COMMIT
# DATABASE_URL=PLACEHOLDER_DO_NOT_COMMIT
# R2_ACCESS_KEY=PLACEHOLDER_DO_NOT_COMMIT
# R2_SECRET_KEY=PLACEHOLDER_DO_NOT_COMMIT
